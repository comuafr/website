---
interface Props {
  name: string;
  price: number;
  image: string;
  description: string;
  slug: string;
  inStock: boolean;
}

const { name, price, image, description, slug, inStock } = Astro.props;

const formattedPrice = new Intl.NumberFormat('fr-FR', {
  style: 'currency',
  currency: 'EUR',
}).format(price);
---

<a href={`/poterie/${slug}`} class="group block bg-bg-secondary rounded-xl border border-border overflow-hidden hover:border-poterie hover:shadow-[0_0_30px_rgba(205,133,63,0.1)] transition-all duration-300">
  <!-- Image -->
  <div class="aspect-square overflow-hidden bg-bg-elevated">
    <img
      src={image}
      alt={name}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
    />
  </div>

  <!-- Info -->
  <div class="p-5">
    <h3 class="text-lg font-semibold text-text-primary mb-1 group-hover:text-poterie transition-colors duration-300">
      {name}
    </h3>
    <p class="text-sm text-text-secondary mb-3 line-clamp-2">
      {description}
    </p>
    <div class="flex items-center justify-between">
      <span class="text-xl font-bold text-primary">{formattedPrice}</span>
      {inStock ? (
        <span class="text-xs text-green-400 bg-green-400/10 px-2 py-1 rounded-full">En stock</span>
      ) : (
        <span class="text-xs text-text-secondary bg-bg-elevated px-2 py-1 rounded-full">Indisponible</span>
      )}
    </div>
  </div>
</a>
