---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  [key: string]: any;
}

const { href, variant = 'primary', size = 'md', class: className = '', ...rest } = Astro.props;

const baseClasses = 'inline-flex items-center justify-center font-medium rounded-lg transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-primary/50';

const variants = {
  primary: 'bg-primary text-white hover:bg-primary-dark active:scale-[0.98] shadow-lg shadow-primary/20',
  secondary: 'bg-bg-elevated text-text-primary border border-border hover:bg-bg-surface hover:border-text-secondary',
  ghost: 'text-text-secondary hover:text-text-primary hover:bg-bg-elevated',
};

const sizes = {
  sm: 'px-4 py-2 text-sm gap-2',
  md: 'px-6 py-3 text-sm gap-2',
  lg: 'px-8 py-4 text-base gap-3',
};

const classes = `${baseClasses} ${variants[variant]} ${sizes[size]} ${className}`;

const Tag = href ? 'a' : 'button';
---

<Tag href={href} class={classes} {...rest}>
  <slot />
</Tag>
