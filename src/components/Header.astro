---
import { t, localePath, frenchPath, locales, localeNames, type Locale } from '../i18n';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale || 'fr';

const flags: Record<Locale, string> = {
  fr: '\u{1F1EB}\u{1F1F7}',
  en: '\u{1F1EC}\u{1F1E7}',
  de: '\u{1F1E9}\u{1F1EA}',
  es: '\u{1F1EA}\u{1F1F8}',
  it: '\u{1F1EE}\u{1F1F9}',
};

const navLinks = [
  { key: 'usinage', label: t('nav.machining', locale) },
  { key: 'soudure', label: t('nav.welding', locale) },
  { key: 'poterie', label: t('nav.pottery', locale) },
  { key: 'ingenierie', label: t('nav.engineering', locale) },
  { key: 'contact', label: t('nav.contact', locale) },
].map(link => ({
  href: localePath(`/${link.key}`, locale),
  label: link.label,
}));

// Add home at the beginning
navLinks.unshift({ href: localePath('/', locale), label: t('nav.home', locale) });

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-bg-primary/90 backdrop-blur-md border-b border-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href={localePath('/', locale)} class="flex items-center gap-3 group">
        <img src="/images/logo.png" alt="COMUA" width="40" height="40" class="w-10 h-10 transition-transform group-hover:rotate-45 duration-500" />
        <span class="text-xl font-bold font-[family-name:var(--font-heading)] tracking-tight text-text-primary">
          COMUA
        </span>
      </a>

      <!-- Desktop Navigation -->
      <nav aria-label={t('a11y.main_nav', locale)} class="hidden lg:flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200',
              currentPath === link.href || (link.href !== localePath('/', locale) && currentPath.startsWith(link.href))
                ? 'text-primary bg-primary/10'
                : 'text-text-secondary hover:text-text-primary hover:bg-bg-elevated'
            ]}
          >
            {link.label}
          </a>
        ))}
        <!-- Language switcher -->
        <LanguageSwitcher locale={locale} />
        <!-- Cart button -->
        <button class="snipcart-checkout ml-2 relative p-2 rounded-lg text-text-secondary hover:text-primary hover:bg-bg-elevated transition-all duration-200" aria-label={t('a11y.cart', locale)}>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />
          </svg>
          <span class="snipcart-items-count absolute -top-1 -right-1 bg-primary text-white text-xs w-5 h-5 rounded-full flex items-center justify-center font-bold" aria-hidden="true"></span>
        </button>
      </nav>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-lg text-text-secondary hover:text-text-primary hover:bg-bg-elevated transition-all"
        aria-label={t('a11y.open_menu', locale)}
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="menu-icon-open" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="menu-icon-close" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <div id="mobile-menu" class="lg:hidden hidden border-t border-border bg-bg-primary/95 backdrop-blur-md">
    <nav aria-label={t('a11y.mobile_nav', locale)} class="px-4 py-4 space-y-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'block px-4 py-3 rounded-lg text-sm font-medium transition-all duration-200',
            currentPath === link.href || (link.href !== localePath('/', locale) && currentPath.startsWith(link.href))
              ? 'text-primary bg-primary/10'
              : 'text-text-secondary hover:text-text-primary hover:bg-bg-elevated'
          ]}
        >
          {link.label}
        </a>
      ))}
      <!-- Mobile language switcher -->
      <div class="px-4 py-3 flex flex-wrap gap-2">
        {locales.map(loc => (
          <a
            href={localePath(frenchPath(currentPath, locale), loc)}
            class:list={[
              'text-xs px-2 py-1 rounded',
              loc === locale
                ? 'bg-primary/10 text-primary font-bold'
                : 'text-text-secondary hover:text-text-primary'
            ]}
          >
            <span class="text-sm leading-none">{flags[loc]}</span> {loc.toUpperCase()}
          </a>
        ))}
      </div>
      <button class="snipcart-checkout w-full flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium text-text-secondary hover:text-primary hover:bg-bg-elevated transition-all duration-200" aria-label={t('a11y.cart', locale)}>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />
        </svg>
        {t('footer.cart', locale)} (<span class="snipcart-items-count">0</span>)
      </button>
    </nav>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16 lg:h-20" aria-hidden="true"></div>

<script is:inline>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');
  const openLabel = btn.getAttribute('aria-label');
  const closeLabel = btn.dataset.closeLabel || 'Close menu';

  function toggleMenu() {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden');
    iconOpen.classList.toggle('hidden');
    iconClose.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  }

  btn.addEventListener('click', toggleMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !menu.classList.contains('hidden')) {
      toggleMenu();
      btn.focus();
    }
  });
</script>
