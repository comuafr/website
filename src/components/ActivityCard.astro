---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
  accentColor: string;
}

const { title, description, href, icon, accentColor } = Astro.props;
---

<a href={href} class="animate-on-scroll group block bg-bg-secondary rounded-xl border border-border p-6 lg:p-8 hover:border-[var(--accent)] hover:shadow-[0_0_30px_var(--accent-glow)] transition-all duration-300" style={`--accent: ${accentColor}; --accent-glow: ${accentColor}20;`}>
  <!-- Icon -->
  <div class="w-14 h-14 rounded-lg bg-bg-elevated flex items-center justify-center mb-5 group-hover:bg-[var(--accent)]/10 transition-colors duration-300">
    <span class="text-3xl" set:html={icon} />
  </div>

  <!-- Content -->
  <h3 class="text-xl font-bold font-[family-name:var(--font-heading)] text-text-primary mb-3 group-hover:text-[var(--accent)] transition-colors duration-300">
    {title}
  </h3>
  <p class="text-text-secondary text-sm leading-relaxed mb-4">
    {description}
  </p>

  <!-- Arrow link -->
  <span class="inline-flex items-center gap-2 text-sm font-medium text-text-secondary group-hover:text-[var(--accent)] transition-all duration-300">
    En savoir plus
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
    </svg>
  </span>
</a>
