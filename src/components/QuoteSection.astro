---
import Container from './ui/Container.astro';
---

<section aria-label="Citation" class="py-16 lg:py-24 bg-bg-secondary">
  <Container>
    <div class="max-w-3xl mx-auto text-center">
      <!-- Decorative line -->
      <div class="w-16 h-0.5 bg-primary mx-auto mb-8"></div>

      <blockquote class="text-xl sm:text-2xl lg:text-3xl font-light italic text-text-primary leading-relaxed mb-6">
        "Les deux sources dont jaillissent toute richesse sont la terre et les travailleurs"
      </blockquote>

      <!-- Decorative gear divider -->
      <div class="flex items-center justify-center gap-4 mt-8">
        <div class="w-12 h-px bg-border"></div>
        <img src="/favicon.svg" alt="" class="w-8 h-8 opacity-30" />
        <div class="w-12 h-px bg-border"></div>
      </div>

      <p class="mt-8 text-text-secondary">
        Chez COMUA, nous conjuguons savoir-faire artisanal et expertise technique
        pour donner vie à vos projets.
      </p>
    </div>
  </Container>
</section>
