---
import Container from './ui/Container.astro';
import { t, getLocale, type Locale } from '../i18n';

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale || getLocale(Astro);
---

<section aria-label="Citation" class="py-16 lg:py-24 bg-bg-secondary">
  <Container>
    <div class="max-w-3xl mx-auto text-center">
      <div class="w-16 h-0.5 bg-primary mx-auto mb-8"></div>

      <blockquote class="text-xl sm:text-2xl lg:text-3xl font-light italic text-text-primary leading-relaxed mb-6">
        {t('quote.tagline', locale)}
      </blockquote>

      <div class="flex items-center justify-center gap-4 mt-8">
        <div class="w-12 h-px bg-border"></div>
        <img src="/images/logo.png" alt="" class="w-8 h-8 opacity-30" />
        <div class="w-12 h-px bg-border"></div>
      </div>

      <p class="mt-8 text-text-secondary">
        {t('quote.description', locale)}
      </p>
    </div>
  </Container>
</section>
