---
const currentYear = new Date().getFullYear();

const activities = [
  { href: '/usinage', label: 'Usinage' },
  { href: '/soudure', label: 'Soudure' },
  { href: '/poterie', label: 'Tours de potier' },
  { href: '/ingenierie', label: 'Ingénierie informatique' },
];

const legal = [
  { href: '/mentions-legales', label: 'Mentions légales' },
  { href: '/politique-retours', label: 'Politique de retours' },
];
---

<footer class="bg-bg-secondary border-t border-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-3 mb-4">
          <img src="/images/logo.png" alt="COMUA" class="w-8 h-8" />
          <span class="text-lg font-bold font-[family-name:var(--font-heading)] text-text-primary">COMUA</span>
        </a>
        <p class="text-text-secondary text-sm leading-relaxed italic">
          "Les deux sources dont jaillissent toute richesse sont la terre et les travailleurs"
        </p>
      </div>

      <!-- Activities -->
      <div>
        <h3 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-4">Nos activités</h3>
        <ul class="space-y-2">
          {activities.map(link => (
            <li>
              <a href={link.href} class="text-sm text-text-secondary hover:text-primary transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-4">Contact</h3>
        <ul class="space-y-2">
          <li>
            <a href="mailto:contact@comua.fr" class="text-sm text-text-secondary hover:text-primary transition-colors flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              contact@comua.fr
            </a>
          </li>
          <li>
            <a href="tel:+33645872339" class="text-sm text-text-secondary hover:text-primary transition-colors flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              +33 6 45 87 23 39
            </a>
          </li>
          <li>
            <a href="https://www.linkedin.com/company/comua" target="_blank" rel="noopener noreferrer" class="text-sm text-text-secondary hover:text-primary transition-colors flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>
          </li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-4">Informations</h3>
        <ul class="space-y-2">
          {legal.map(link => (
            <li>
              <a href={link.href} class="text-sm text-text-secondary hover:text-primary transition-colors">
                {link.label}
              </a>
            </li>
          ))}
          <li>
            <a href="/poterie" class="text-sm text-text-secondary hover:text-primary transition-colors">
              Boutique
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-border flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-text-secondary">
        &copy; {currentYear} COMUA. Tous droits réservés.
      </p>
      <button class="snipcart-checkout text-xs text-text-secondary hover:text-primary transition-colors flex items-center gap-1" aria-label="Ouvrir le panier">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />
        </svg>
        Panier (<span class="snipcart-items-count">0</span>)
      </button>
    </div>
  </div>
</footer>
