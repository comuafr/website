---
interface Props {
  capabilities: Array<{
    title: string;
    description: string;
  }>;
  accentColor: string;
}

const { capabilities, accentColor } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
  {capabilities.map((cap) => (
    <div class="bg-bg-secondary rounded-xl border border-border p-6 hover:border-[var(--accent)] transition-colors duration-300" style={`--accent: ${accentColor};`}>
      <div class="w-10 h-10 rounded-lg bg-[var(--accent)]/10 flex items-center justify-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" style={`color: ${accentColor};`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-text-primary mb-2">{cap.title}</h3>
      <p class="text-sm text-text-secondary leading-relaxed">{cap.description}</p>
    </div>
  ))}
</div>
