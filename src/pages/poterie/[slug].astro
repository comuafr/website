---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import Button from '../../components/ui/Button.astro';
import ProductGrid from '../../components/ProductGrid.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map(product => ({
    params: { slug: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const { Content } = await render(product);
const { name, price, image, description, specs, inStock, category } = product.data;

const formattedPrice = new Intl.NumberFormat('fr-FR', {
  style: 'currency',
  currency: 'EUR',
}).format(price);

// Related products
const allProducts = await getCollection('products');
const related = allProducts.filter(p => p.id !== product.id && p.data.category === category).slice(0, 3);
---

<BaseLayout title={`${name} — COMUA`} description={description}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": name,
    "description": description,
    "image": `https://comua.fr${image}`,
    "offers": {
      "@type": "Offer",
      "price": price,
      "priceCurrency": "EUR",
      "availability": inStock ? "https://schema.org/InStock" : "https://schema.org/OutOfStock",
      "url": `https://comua.fr/poterie/${product.id}`
    },
    "brand": { "@type": "Brand", "name": "COMUA" }
  })} />

  <section class="py-12 lg:py-20">
    <Container>
      <!-- Breadcrumb -->
      <nav aria-label="Fil d'Ariane" class="mb-8">
        <ol class="flex items-center gap-2 text-sm">
          <li><a href="/" class="text-text-secondary hover:text-primary transition-colors">Accueil</a></li>
          <li aria-hidden="true" class="text-text-secondary/40">/</li>
          <li><a href="/poterie" class="text-text-secondary hover:text-primary transition-colors">Boutique</a></li>
          <li aria-hidden="true" class="text-text-secondary/40">/</li>
          <li aria-current="page" class="text-poterie">{name}</li>
        </ol>
      </nav>

      <!-- Product -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16">
        <!-- Image -->
        <div class="aspect-square rounded-2xl overflow-hidden bg-bg-secondary border border-border">
          <img src={image} alt={name} width="400" height="400" decoding="async" class="w-full h-full object-cover" />
        </div>

        <!-- Info -->
        <div class="flex flex-col">
          <h1 class="text-3xl sm:text-4xl font-extrabold text-text-primary mb-3" style="font-family: var(--font-heading);">
            {name}
          </h1>

          <p class="text-text-secondary text-lg mb-6 leading-relaxed">
            {description}
          </p>

          <div class="flex items-center gap-4 mb-6">
            <span class="text-3xl font-bold text-primary">{formattedPrice}</span>
            <span class="text-sm text-text-secondary">TTC</span>
            {inStock ? (
              <span class="text-sm text-green-400 bg-green-400/10 px-3 py-1 rounded-full">En stock</span>
            ) : (
              <span class="text-sm text-text-secondary bg-bg-elevated px-3 py-1 rounded-full">Indisponible</span>
            )}
          </div>

          <!-- Snipcart Buy Button -->
          {inStock && (
            <button
              class="snipcart-add-item w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-primary text-white font-medium rounded-lg px-8 py-4 text-lg hover:bg-primary-dark active:scale-[0.98] transition-all duration-200 shadow-lg shadow-primary/20 mb-8"
              data-item-id={product.id}
              data-item-price={price}
              data-item-url={`/poterie/${product.id}`}
              data-item-name={name}
              data-item-description={description}
              data-item-image={image}
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />
              </svg>
              Ajouter au panier
            </button>
          )}

          <!-- Specs -->
          {specs && Object.keys(specs).length > 0 && (
            <div class="border-t border-border pt-6">
              <h3 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-4">Caractéristiques</h3>
              <dl class="space-y-3">
                {Object.entries(specs).map(([key, value]) => (
                  <div class="flex justify-between">
                    <dt class="text-sm text-text-secondary">{key}</dt>
                    <dd class="text-sm text-text-primary font-medium">{value}</dd>
                  </div>
                ))}
              </dl>
            </div>
          )}
        </div>
      </div>

      <!-- Description longue -->
      <div class="mt-16 max-w-3xl prose prose-invert prose-lg
        prose-headings:font-[family-name:var(--font-heading)] prose-headings:text-text-primary
        prose-p:text-text-secondary prose-p:leading-relaxed
        prose-strong:text-text-primary">
        <Content />
      </div>
    </Container>
  </section>

  <!-- Related products -->
  {related.length > 0 && (
    <section class="py-16 lg:py-24 bg-bg-secondary">
      <Container>
        <h2 class="text-2xl font-bold text-text-primary mb-10" style="font-family: var(--font-heading);">
          Produits similaires
        </h2>
        <ProductGrid products={related} />
      </Container>
    </section>
  )}
</BaseLayout>
