---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import { t } from '../i18n';
---

<BaseLayout title={`${t('legal.title', 'fr')} — COMUA`} description={t('legal.meta_description', 'fr')} pathKey="/mentions-legales">
  <section class="py-20 lg:py-32">
    <Container>
      <div class="max-w-3xl mx-auto">
        <h1 class="text-3xl sm:text-4xl font-extrabold text-text-primary mb-10" style="font-family: var(--font-heading);">
          {t('legal.title', 'fr')}
        </h1>

        <div class="prose prose-invert prose-lg
          prose-headings:font-[family-name:var(--font-heading)] prose-headings:text-text-primary
          prose-p:text-text-secondary prose-p:leading-relaxed
          prose-strong:text-text-primary
          prose-li:text-text-secondary
          prose-a:text-primary">

          <h2>{t('legal.editor', 'fr')}</h2>
          <p>
            <strong>COMUA</strong><br />
            2 route du Burgaud, 82600 Aucamville<br />
            Email : <a href="#" data-ob-email><span data-ob-email-text>Email</span></a><br />
            {t('footer.phone', 'fr')} : <a href="#" data-ob-tel><span data-ob-tel-text>{t('footer.phone', 'fr')}</span></a>
          </p>

          <h2>{t('legal.hosting', 'fr')}</h2>
          <p>
            {t('legal.hosting_text', 'fr')}<br />
            44 Montgomery Street, Suite 300<br />
            San Francisco, California 94104, USA
          </p>

          <h2>{t('legal.ip', 'fr')}</h2>
          <p>{t('legal.ip_text', 'fr')}</p>

          <h2>{t('legal.data', 'fr')}</h2>
          <p>
            {t('legal.data_text', 'fr')} <a href="#" data-ob-email><span data-ob-email-text>email</span></a>.
          </p>

          <h2>{t('legal.cookies', 'fr')}</h2>
          <p>{t('legal.cookies_text', 'fr')}</p>

          <h2>{t('legal.liability', 'fr')}</h2>
          <p>{t('legal.liability_text', 'fr')}</p>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
