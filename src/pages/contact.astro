---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import { t } from '../i18n';
---

<BaseLayout title={t('meta.contact_title', 'fr')} description={t('meta.contact_description', 'fr')} pathKey="/contact">
  <section class="pt-10 pb-10 lg:pt-16 lg:pb-12">
    <Container>
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-16">
          <h1 class="text-4xl sm:text-5xl font-extrabold text-text-primary mb-4" style="font-family: var(--font-heading);">
            {t('contact.title', 'fr')}
          </h1>
          <p class="text-xl text-text-secondary max-w-2xl mx-auto">
            {t('contact.subtitle', 'fr')}
          </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-16">
          <!-- Form -->
          <div class="lg:col-span-3">
            <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="space-y-6">
              <input type="hidden" name="form-name" value="contact" />
              <p class="hidden">
                <label>{t('contact.do_not_fill', 'fr')} : <input name="bot-field" /></label>
              </p>
              <p class="text-sm text-text-secondary">{t('contact.required_fields', 'fr')}</p>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <label for="name" class="block text-sm font-medium text-text-primary mb-2">{t('contact.name_label', 'fr')} *</label>
                  <input
                    type="text" id="name" name="name" required
                    class="w-full bg-bg-secondary border border-border rounded-lg px-4 py-3 text-text-primary placeholder-text-secondary/50 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all"
                    placeholder={t('contact.name_placeholder', 'fr')}
                  />
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium text-text-primary mb-2">{t('contact.email_label', 'fr')} *</label>
                  <input
                    type="email" id="email" name="email" required
                    class="w-full bg-bg-secondary border border-border rounded-lg px-4 py-3 text-text-primary placeholder-text-secondary/50 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all"
                    placeholder={t('contact.email_placeholder', 'fr')}
                  />
                </div>
              </div>

              <div>
                <label for="subject" class="block text-sm font-medium text-text-primary mb-2">{t('contact.subject_label', 'fr')} *</label>
                <select id="subject" name="subject" required
                  class="w-full bg-bg-secondary border border-border rounded-lg px-4 py-3 text-text-primary focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all">
                  <option value="" disabled selected>{t('contact.subject_default', 'fr')}</option>
                  <option value="usinage">{t('contact.subject_machining', 'fr')}</option>
                  <option value="soudure">{t('contact.subject_welding', 'fr')}</option>
                  <option value="poterie">{t('contact.subject_pottery', 'fr')}</option>
                  <option value="ingenierie">{t('contact.subject_engineering', 'fr')}</option>
                  <option value="autre">{t('contact.subject_other', 'fr')}</option>
                </select>
              </div>

              <div>
                <label for="phone" class="block text-sm font-medium text-text-primary mb-2">{t('contact.phone_label', 'fr')}</label>
                <input
                  type="tel" id="phone" name="phone"
                  class="w-full bg-bg-secondary border border-border rounded-lg px-4 py-3 text-text-primary placeholder-text-secondary/50 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all"
                  placeholder={t('contact.phone_placeholder', 'fr')}
                />
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-text-primary mb-2">{t('contact.message_label', 'fr')} *</label>
                <textarea
                  id="message" name="message" required rows="6"
                  class="w-full bg-bg-secondary border border-border rounded-lg px-4 py-3 text-text-primary placeholder-text-secondary/50 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all resize-y"
                  placeholder={t('contact.message_placeholder', 'fr')}
                ></textarea>
              </div>

              <button type="submit"
                class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-primary text-white font-medium rounded-lg px-8 py-4 hover:bg-primary-dark active:scale-[0.98] transition-all duration-200 shadow-lg shadow-primary/20">
                {t('contact.submit', 'fr')}
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                </svg>
              </button>
            </form>
          </div>

          <!-- Contact info sidebar -->
          <div class="lg:col-span-2 space-y-8">
            <div class="bg-bg-secondary rounded-xl border border-border p-6">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-text-primary mb-1">{t('footer.email', 'fr')}</h3>
                  <a href="#" data-ob-email class="text-text-secondary hover:text-primary transition-colors"><span data-ob-email-text>{t('footer.email', 'fr')}</span></a>
                </div>
              </div>
            </div>

            <div class="bg-bg-secondary rounded-xl border border-border p-6">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-text-primary mb-1">{t('footer.phone', 'fr')}</h3>
                  <a href="#" data-ob-tel class="text-text-secondary hover:text-primary transition-colors"><span data-ob-tel-text>{t('footer.phone', 'fr')}</span></a>
                </div>
              </div>
            </div>

            <div class="bg-bg-secondary rounded-xl border border-border p-6">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-text-primary mb-1">{t('footer.linkedin', 'fr')}</h3>
                  <a href="https://www.linkedin.com/company/comua" target="_blank" rel="noopener noreferrer" class="text-text-secondary hover:text-primary transition-colors">{t('contact.follow_us', 'fr')}</a>
                </div>
              </div>
            </div>

            <div class="bg-bg-secondary rounded-xl border border-border p-6">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-text-primary mb-1">{t('contact.address', 'fr')}</h3>
                  <p class="text-text-secondary text-sm">2 route du Burgaud<br />82600 Aucamville</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
