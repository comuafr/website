---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import { t } from '../i18n';
---

<BaseLayout title={`${t('returns.title', 'fr')} — COMUA`} description={t('returns.meta_description', 'fr')} pathKey="/politique-retours">
  <section class="py-20 lg:py-32">
    <Container>
      <div class="max-w-3xl mx-auto">
        <h1 class="text-3xl sm:text-4xl font-extrabold text-text-primary mb-10" style="font-family: var(--font-heading);">
          {t('returns.title', 'fr')}
        </h1>

        <div class="prose prose-invert prose-lg
          prose-headings:font-[family-name:var(--font-heading)] prose-headings:text-text-primary
          prose-p:text-text-secondary prose-p:leading-relaxed
          prose-strong:text-text-primary
          prose-li:text-text-secondary
          prose-a:text-primary">

          <h2>{t('returns.withdrawal', 'fr')}</h2>
          <p set:html={t('returns.withdrawal_text', 'fr')} />

          <h2>{t('returns.conditions', 'fr')}</h2>
          <p>{t('returns.conditions_intro', 'fr')}</p>
          <ul>
            <li>{t('returns.condition_1', 'fr')}</li>
            <li>{t('returns.condition_2', 'fr')}</li>
            <li>{t('returns.condition_3', 'fr')}</li>
          </ul>

          <h2>{t('returns.procedure', 'fr')}</h2>
          <ol>
            <li>{t('returns.procedure_1', 'fr')}</li>
            <li>{t('returns.procedure_2', 'fr')}</li>
            <li>{t('returns.procedure_3', 'fr')}</li>
            <li>{t('returns.procedure_4', 'fr')}</li>
          </ol>

          <h2>{t('returns.refund', 'fr')}</h2>
          <p>{t('returns.refund_text', 'fr')}</p>

          <h2>{t('returns.defective', 'fr')}</h2>
          <p set:html={t('returns.defective_text', 'fr')} />

          <h2>{t('returns.contact', 'fr')}</h2>
          <p>
            {t('returns.contact_text', 'fr')}<br />
            Email : <a href="#" data-ob-email><span data-ob-email-text>Email</span></a><br />
            {t('footer.phone', 'fr')} : <a href="#" data-ob-tel><span data-ob-tel-text>{t('footer.phone', 'fr')}</span></a>
          </p>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
