---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/ui/Container.astro';
import ProductGrid from '../../../components/ProductGrid.astro';
import ContactCTA from '../../../components/ContactCTA.astro';
import { getCollection } from 'astro:content';
import { t, locales, localePath, routeMap, type Locale } from '../../../i18n';

export async function getStaticPaths() {
  const allProducts = await getCollection('products');
  return locales.filter(l => l !== 'fr').map(locale => {
    // Prefer locale-specific products, fallback to French
    const frProducts = allProducts.filter(p => p.data.locale === 'fr');
    const localeProducts = allProducts.filter(p => p.data.locale === locale);
    const products = frProducts.map(frP => {
      const slug = frP.id.includes('/') ? frP.id.split('/').pop()! : frP.id;
      const locP = localeProducts.find(p => (p.id.includes('/') ? p.id.split('/').pop()! : p.id) === slug);
      return locP || frP;
    });
    return {
      params: { locale, shop: routeMap[locale]['poterie'] },
      props: { locale, products },
    };
  });
}

const { locale, products } = Astro.props as { locale: Locale; products: any[] };
const tours = products.filter((p: any) => p.data.category === 'tours');
const accessoires = products.filter((p: any) => p.data.category === 'accessoires');
---

<BaseLayout title={t('meta.shop_title', locale)} description={t('meta.shop_description', locale)} pathKey="/poterie">
  <section class="relative py-20 lg:py-32 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-poterie/5 to-transparent"></div>
    <Container class="relative z-10">
      <div class="max-w-3xl">
        <nav aria-label={t('a11y.breadcrumb', locale)} class="flex items-center gap-3 mb-6">
          <div class="w-12 h-12 rounded-lg flex items-center justify-center text-2xl bg-poterie/10">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 9h18c0 5.523-4.029 10-9 10S3 14.523 3 9z" /><path stroke-linecap="round" stroke-linejoin="round" d="M7 20h10" /></svg>
          </div>
          <ol class="flex items-center gap-2 text-sm">
            <li><a href={localePath('/', locale)} class="text-text-secondary hover:text-primary transition-colors">{t('nav.home', locale)}</a></li>
            <li aria-hidden="true" class="text-text-secondary/40">/</li>
            <li aria-current="page" class="text-poterie">{t('shop.breadcrumb', locale)}</li>
          </ol>
        </nav>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-text-primary mb-4" style="font-family: var(--font-heading);">
          {t('shop.title', locale)}
        </h1>
        <p class="text-xl lg:text-2xl text-text-secondary leading-relaxed">
          {t('shop.description', locale)}
        </p>
      </div>
    </Container>
  </section>

  <section class="py-16 lg:py-24">
    <Container>
      <h2 class="text-2xl lg:text-3xl font-bold text-text-primary mb-10" style="font-family: var(--font-heading);">
        {t('product.our_wheels', locale)}
      </h2>
      <ProductGrid products={tours} locale={locale} />
    </Container>
  </section>

  <section class="py-16 lg:py-24 bg-bg-secondary">
    <Container>
      <h2 class="text-2xl lg:text-3xl font-bold text-text-primary mb-10" style="font-family: var(--font-heading);">
        {t('product.accessories', locale)}
      </h2>
      <ProductGrid products={accessoires} locale={locale} />
    </Container>
  </section>

  <ContactCTA locale={locale} />
</BaseLayout>
