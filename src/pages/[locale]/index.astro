---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import ActivityGrid from '../../components/ActivityGrid.astro';
import QuoteSection from '../../components/QuoteSection.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import { t, locales, type Locale } from '../../i18n';

export function getStaticPaths() {
  return locales.filter(l => l !== 'fr').map(locale => ({
    params: { locale },
    props: { locale },
  }));
}

const { locale } = Astro.props as { locale: Locale };
---

<BaseLayout title={t('meta.home_title', locale)} pathKey="/">
  <Hero locale={locale} />
  <ActivityGrid locale={locale} />
  <QuoteSection locale={locale} />
  <ContactCTA locale={locale} />
</BaseLayout>
